# Copy to .env on the server (never commit real secrets)

# PostgreSQL — use Coolify Postgres internal URL, e.g.:
# Host=postgres;Port=5432;Database=tms_pro;Username=tms;Password=CHANGE_ME
TMS_CONNECTION_STRING=Host=YOUR_PG_HOST;Port=5432;Database=tms_pro;Username=tms;Password=CHANGE_ME

# Min 32 characters — generate: openssl rand -base64 48
TMS_JWT_KEY=REPLACE_WITH_32_PLUS_CHARACTER_SECRET_KEY

# First deploy only; set false after DB is migrated
Database__RunStartupMigrations=true
Database__FailOnMigrationError=false
DemoData__Enabled=false
Gps__AllowSimulator=false

# Public URL users open in browser (Coolify domain or VPS IP)
Cors__Origins__0=http://144.91.98.218

# Host port for web container (Coolify may assign automatically)
TMS_WEB_PORT=80
