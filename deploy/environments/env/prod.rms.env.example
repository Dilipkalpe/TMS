# RMS Production — copy to /var/www/prod/rms/.env

COMPOSE_PROJECT_NAME=prod-rms
ENV_NAME=production
APP_CODE=rms

DB_NAME=RMS_PROD_DB
DB_USER=rms_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

APP_ROOT=/var/www/prod/rms
UPLOADS_DIR=/var/www/prod/rms/uploads
LOGS_DIR=/var/www/prod/rms/logs
BACKUP_DIR=/var/www/prod/rms/backups

WEB_HOST_PORT=8103
API_HOST_PORT=5103

APP_URL=https://rms.company.com
API_URL=https://api-rms.company.com

RMS_JWT_KEY=REPLACE_WITH_32_PLUS_CHARACTER_SECRET_KEY

ASPNETCORE_ENVIRONMENT=Production
RELEASE_TAG=latest
API_IMAGE=local/rms-api
WEB_IMAGE=local/rms-web

GIT_REMOTE=origin
GIT_BRANCH=main
