# TMS Production — copy to /var/www/prod/tms/.env
# NEVER commit real secrets.

COMPOSE_PROJECT_NAME=prod-tms
ENV_NAME=production
APP_CODE=tms

# Database (isolated production DB)
DB_NAME=TMS_PROD_DB
DB_USER=tms_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Host paths (created by setup-server.sh)
APP_ROOT=/var/www/prod/tms
UPLOADS_DIR=/var/www/prod/tms/uploads
LOGS_DIR=/var/www/prod/tms/logs
BACKUP_DIR=/var/www/prod/tms/backups

# Published ports (host nginx proxies here)
WEB_HOST_PORT=8101
API_HOST_PORT=5101

# Public URLs
APP_URL=https://tms.company.com
API_URL=https://api-tms.company.com

# Application secrets
TMS_JWT_KEY=REPLACE_WITH_32_PLUS_CHARACTER_SECRET_KEY

# Production settings
ASPNETCORE_ENVIRONMENT=Production
Database__RunStartupMigrations=true
Database__FailOnMigrationError=false
DemoData__Enabled=false
Gps__AllowSimulator=false

# Docker image tags (set by deploy script)
RELEASE_TAG=latest
API_IMAGE=local/tms-api
WEB_IMAGE=local/tms-web

# Git remote (optional — used by deploy script)
GIT_REMOTE=origin
GIT_BRANCH=main
