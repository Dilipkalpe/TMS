# TMS Demo / UAT — copy to /var/www/demo/tms/.env

COMPOSE_PROJECT_NAME=demo-tms
ENV_NAME=demo
APP_CODE=tms

DB_NAME=TMS_DEMO_DB
DB_USER=tms_demo
POSTGRES_PASSWORD=CHANGE_ME_DEMO_PASSWORD

APP_ROOT=/var/www/demo/tms
UPLOADS_DIR=/var/www/demo/tms/uploads
LOGS_DIR=/var/www/demo/tms/logs
BACKUP_DIR=/var/www/demo/tms/backups

WEB_HOST_PORT=8201
API_HOST_PORT=5201

APP_URL=https://demo-tms.company.com
API_URL=https://demo-api-tms.company.com

TMS_JWT_KEY=REPLACE_WITH_DEMO_ONLY_SECRET_DIFFERENT_FROM_PROD

ASPNETCORE_ENVIRONMENT=Staging
Database__RunStartupMigrations=true
Database__FailOnMigrationError=false
DemoData__Enabled=true
Gps__AllowSimulator=true

RELEASE_TAG=latest
API_IMAGE=local/tms-api
WEB_IMAGE=local/tms-web

GIT_REMOTE=origin
GIT_BRANCH=main
