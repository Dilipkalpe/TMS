# RMS Demo — copy to /var/www/demo/rms/.env

COMPOSE_PROJECT_NAME=demo-rms
ENV_NAME=demo
APP_CODE=rms

DB_NAME=RMS_DEMO_DB
DB_USER=rms_demo
POSTGRES_PASSWORD=CHANGE_ME_DEMO_PASSWORD

APP_ROOT=/var/www/demo/rms
UPLOADS_DIR=/var/www/demo/rms/uploads
LOGS_DIR=/var/www/demo/rms/logs
BACKUP_DIR=/var/www/demo/rms/backups

WEB_HOST_PORT=8203
API_HOST_PORT=5203

APP_URL=https://demo-rms.company.com
API_URL=https://demo-api-rms.company.com

RMS_JWT_KEY=REPLACE_WITH_DEMO_ONLY_SECRET

ASPNETCORE_ENVIRONMENT=Staging
RELEASE_TAG=latest
API_IMAGE=local/rms-api
WEB_IMAGE=local/rms-web

GIT_REMOTE=origin
GIT_BRANCH=main
