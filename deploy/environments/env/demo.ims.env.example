# IMS Demo — copy to /var/www/demo/ims/.env

COMPOSE_PROJECT_NAME=demo-ims
ENV_NAME=demo
APP_CODE=ims

DB_NAME=IMS_DEMO_DB
DB_USER=ims_demo
POSTGRES_PASSWORD=CHANGE_ME_DEMO_PASSWORD

APP_ROOT=/var/www/demo/ims
UPLOADS_DIR=/var/www/demo/ims/uploads
LOGS_DIR=/var/www/demo/ims/logs
BACKUP_DIR=/var/www/demo/ims/backups

WEB_HOST_PORT=8202
API_HOST_PORT=5202

APP_URL=https://demo-ims.company.com
API_URL=https://demo-api-ims.company.com

IMS_JWT_KEY=REPLACE_WITH_DEMO_ONLY_SECRET

ASPNETCORE_ENVIRONMENT=Staging
RELEASE_TAG=latest
API_IMAGE=local/ims-api
WEB_IMAGE=local/ims-web

GIT_REMOTE=origin
GIT_BRANCH=main
