# IMS Production — copy to /var/www/prod/ims/.env

COMPOSE_PROJECT_NAME=prod-ims
ENV_NAME=production
APP_CODE=ims

DB_NAME=IMS_PROD_DB
DB_USER=ims_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

APP_ROOT=/var/www/prod/ims
UPLOADS_DIR=/var/www/prod/ims/uploads
LOGS_DIR=/var/www/prod/ims/logs
BACKUP_DIR=/var/www/prod/ims/backups

WEB_HOST_PORT=8102
API_HOST_PORT=5102

APP_URL=https://ims.company.com
API_URL=https://api-ims.company.com

IMS_JWT_KEY=REPLACE_WITH_32_PLUS_CHARACTER_SECRET_KEY

ASPNETCORE_ENVIRONMENT=Production
RELEASE_TAG=latest
API_IMAGE=local/ims-api
WEB_IMAGE=local/ims-web

GIT_REMOTE=origin
GIT_BRANCH=main
